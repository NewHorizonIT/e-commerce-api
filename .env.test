# ============================================================
# TEST ENVIRONMENT
# ============================================================

APP_NAME=e-commerce-api-test
NODE_ENV=test
APP_HOST=localhost
APP_PORT=3001

# Database - Test (separate DB for testing)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=ecommerce_test
DB_SSL=false
DB_SYNC=true
DB_LOGGING=false

# JWT - Test
JWT_ACCESS_TOKEN_SECRET=test_access_token_secret_key
JWT_ACCESS_TOKEN_EXPIRATION=1h
JWT_REFRESH_TOKEN_SECRET=test_refresh_token_secret_key
JWT_REFRESH_TOKEN_EXPIRATION=7d

# Redis - Test (use different DB index)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=1
REDIS_KEY_PREFIX=ecommerce_test:

# Logging - Minimal in tests
LOG_LEVEL=error
LOG_FORMAT=simple

# Rate Limiting - Disabled in tests
RATE_LIMIT_ENABLED=false
